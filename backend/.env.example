# Copy to .env and adjust for local development:
#   cp .env.example .env

# development | production
YORA_ENV=development

# JWT (required in production — use a long random secret)
JWT_SECRET=yora-dev-jwt-secret-change-in-production
JWT_EXPIRE_HOURS=8

# Postman / local dev shortcut — ignored when YORA_ENV=production
AUTH_BYPASS=false
AUTH_BYPASS_TOKEN=yora-postman-local
AUTH_BYPASS_USER_ID=postman
AUTH_BYPASS_USER_NAME=Postman Test

# Optional seed password when running sql/run_yora_users_migration.py
YORA_ADMIN_PASSWORD=admin123

# Comma-separated frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://erp.yorapac.com
